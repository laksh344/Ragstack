# === Provider selection ===
# Which backend powers the chat LLM and the embeddings.
# Options: openai | google | cohere
LLM_PROVIDER=google
EMBEDDING_PROVIDER=google

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# === Google Gemini ===
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# === LangSmith Observability ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2-your-langsmith-key
LANGCHAIN_PROJECT=ragstack

# === Cohere (Reranking; also usable as LLM/embedding provider) ===
COHERE_API_KEY=your-cohere-key

# === Tavily (Web Search) ===
TAVILY_API_KEY=tvly-your-tavily-key

# === Vector Store (Qdrant) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=ragstack

# === Keyword Store (Elasticsearch) ===
ES_HOST=http://localhost:9200
ES_INDEX=ragstack

# === Redis (Session & Cache) ===
REDIS_URL=redis://localhost:6379

# === App Config ===
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
